server
{
    listen 8080;
    root /var/www/html;
    domain_name webserv.com;
    location /images
    {
        root /var/www/images;
        methods GET;
    }
}
server
{
    listen 8081;
    root /var/www/html;
    domain_name webserv.com;
    location /images
    {
        root /var/www/images;
        methods GET;
    }
}
