server {
    listen 8080;
    domain_name localhost;

    root ./Core/www;
    index index.html;
    client_max_body_size 1000000000;

    error_page 400 /errors/400.html;
    error_page 403 /errors/403.html;
    error_page 404 /errors/404.html;
    error_page 405 /errors/405.html;
    error_page 413 /errors/413.html;
    error_page 500 /errors/500.html;
    error_page 501 /errors/501.html;
    error_page 505 /errors/505.html;

    location / {
        methods GET POST DELETE;
    }

    location /browse/ {
        root ./Core/www/browse;
        show_directory true;
        methods GET;
    }

    location /noindex/ {
        root ./Core/www/noindex;
        show_directory false;
        methods GET;
    }

    location /upload/ {
        root ./Core/www/upload;
        upload_dir ./Core/www/upload;
        methods GET POST DELETE;
    }

    location /cgi-bin/ {
        root ./Core/www/cgi-bin;
        methods GET POST;
        cgi_interpreter .py /usr/bin/python3;
    }

    location /readonly/ {
        root ./Core/www;
        methods GET;
    }

    location /redirect/ {
        redirect_page 301 http://www.youtube.com/watch?v=dQw4w9WgXcQ;
    }
}
