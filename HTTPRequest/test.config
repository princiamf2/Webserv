server {
    listen 8080;
    domain_name localhost;

    root /home/michel/Documents/webserv/HTTPRequest/www1;
    index index.html;
    client_max_body_size 1000000;

    error_page 404 /errors/404.html;
    error_page 500 /errors/500.html;

    location / {
        methods GET POST DELETE;
    }

    location /browse/ {
        root /home/michel/Documents/webserv/HTTPRequest/www1/browse;
        show_directory true;
        methods GET;
    }

    location /noindex/ {
        root /home/michel/Documents/webserv/HTTPRequest/www1/noindex;
        show_directory false;
        methods GET;
    }

    location /upload/ {
        root /home/michel/Documents/webserv/HTTPRequest/www1/upload;
        upload_dir /home/michel/Documents/webserv/HTTPRequest/www1/upload;
        methods GET POST DELETE;
    }

    location /cgi-bin/ {
        root /home/michel/Documents/webserv/HTTPRequest/www/cgi-bin;
        methods GET POST;
        cgi_interpreter .py /usr/bin/python3;
    }

    location /readonly/ {
        root /home/michel/Documents/webserv/HTTPRequest/www1;
        methods GET;
    }
}

server {
    listen 8081;
    domain_name localhost;

    root /home/michel/Documents/webserv/HTTPRequest/www2;
    index index.html;
    client_max_body_size 200000;

    error_page 404 /errors/404.html;
    error_page 500 /errors/500.html;

    location / {
        methods GET POST DELETE;
    }

    location /redirect/ {
        redirect_page 301 http://example.com;
    }

    location /upload/ {
        root /home/michel/Documents/webserv/HTTPRequest/www2/upload;
        upload_dir /home/michel/Documents/webserv/HTTPRequest/www2/upload;
        methods GET POST DELETE;
    }

    location /cgi-bin/ {
        root /home/michel/Documents/webserv/HTTPRequest/www2/cgi-bin;
        methods GET POST;
        cgi_interpreter .py /usr/bin/python3;
    }

    location /cgi-php/ {
        root /home/michel/Documents/webserv/HTTPRequest/www2/cgi-php;
        methods GET POST;
        cgi_interpreter .php /usr/bin/php-cgi;
    }

    location /readonly/ {
        root /home/michel/Documents/webserv/HTTPRequest/www2;
        methods GET;
    }
}

server {
    listen 8082;
    domain_name localhost;

    root /home/michel/Documents/webserv/HTTPRequest/www3;
    index index.html;
    client_max_body_size 50000;

    error_page 404 /errors/404.html;

    location / {
        methods GET;
    }

    location /browse/ {
        root /home/michel/Documents/webserv/HTTPRequest/www3/browse;
        show_directory true;
        methods GET;
    }
}